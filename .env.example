# --- Hardening flags (safe defaults: read-only analytics) ---

# Включить управление кампаниями (campaign-editor). По умолчанию — только чтение.
YANDEX_DIRECT_ENABLE_WRITES=

# Включить финансовые операции (deposit/invoice/transfer). Только вместе с writes.
YANDEX_DIRECT_ENABLE_FINANCE=

# Явный профиль поверхности: analytics | core | campaign-editor | full
YANDEX_DIRECT_TOOL_PROFILE=

# Опциональный путь к бинарю `direct` (direct-cli):
YANDEX_DIRECT_CLI_PATH=
